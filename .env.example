# Форма обратной связи: письма приходят на вашу почту через Formspree.
# 1. Зарегистрируйтесь на https://formspree.io
# 2. Создайте новую форму, укажите email polo.zakaz@list.ru
# 3. Подтвердите почту в письме от Formspree (иначе заявки не приходят!)
# 4. Скопируйте ID формы (только часть после /f/ из ссылки, например xpwnqkab)
# 5. Для локальной разработки: скопируйте этот файл в .env и подставьте ID
# 6. Для деплоя на GitHub Pages: в репозитории Settings → Secrets → Actions →
#    создать секрет FORMSPREE_ID со значением вашего ID формы

VITE_FORMSPREE_ID=xvzblngv

# CMS-панель (/admin)
# VITE_ADMIN_PIN      — PIN-код для входа в CMS (по умолчанию: admin)
# VITE_GITHUB_OWNER   — логин владельца репозитория на GitHub (например: myusername)
# VITE_GITHUB_REPO    — название репозитория (например: fabricapolo)
# VITE_GITHUB_TOKEN   — Personal Access Token (fine-grained, rights: contents: write).
#                       Если задан, поле ввода токена в CMS не показывается.
# Для деплоя добавьте эти переменные в Settings → Secrets → Actions
VITE_ADMIN_PIN=ilovetimur
VITE_GITHUB_OWNER=fuckpolitics
VITE_GITHUB_REPO=fabricapolo
VITE_GITHUB_TOKEN=

# Яндекс Метрика (опционально, для вкладки Аналитика в CMS)
# VITE_METRIKA_TOKEN — OAuth-токен Метрики
# VITE_METRIKA_ID    — ID счётчика (8 цифр, из metrika.yandex.ru)
VITE_METRIKA_TOKEN=
VITE_METRIKA_ID=
